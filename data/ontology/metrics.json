[
  {"metric_id": "TOTAL_REVENUE", "name": "Total Revenue", "description": "Sum of all order totals in the period", "formula": "SUM(orders.total_amount)", "valid_range": [0, 1000000000], "unit": "USD", "refresh_frequency": "DAILY", "requires_entities": ["ORDER"], "natural_language_aliases": ["revenue", "total sales", "earnings", "turnover", "gross revenue", "top line"], "aggregation_type": "SUM"},
  {"metric_id": "CUSTOMER_COUNT", "name": "Customer Count", "description": "Number of unique customers", "formula": "COUNT(DISTINCT customers.customer_id)", "valid_range": [0, 1000000], "unit": "COUNT", "refresh_frequency": "DAILY", "requires_entities": ["CUSTOMER"], "natural_language_aliases": ["customer count", "customers", "total customers", "number of customers", "how many customers"], "aggregation_type": "COUNT"},
  {"metric_id": "AVG_ORDER_VALUE", "name": "Average Order Value", "description": "Mean value of orders in the period", "formula": "AVG(orders.total_amount)", "valid_range": [0, 100000], "unit": "USD", "refresh_frequency": "DAILY", "requires_entities": ["ORDER"], "natural_language_aliases": ["avg order value", "average order", "aov", "mean order value", "average basket"], "aggregation_type": "AVG"},
  {"metric_id": "TOTAL_PROFIT", "name": "Total Profit", "description": "Revenue minus cost of goods sold", "formula": "SUM(orders.total_amount - orders.tax_amount - orders.shipping_cost)", "valid_range": [-1000000000, 1000000000], "unit": "USD", "refresh_frequency": "DAILY", "requires_entities": ["ORDER"], "natural_language_aliases": ["profit", "net income", "net profit", "gross profit dollars"], "aggregation_type": "SUM"},
  {"metric_id": "GROSS_MARGIN", "name": "Gross Margin", "description": "Revenue minus COGS as a percentage of revenue", "formula": "ROUND((SUM(total_amount) - SUM(cost)) * 100.0 / NULLIF(SUM(total_amount), 0), 2)", "valid_range": [0, 100], "unit": "PERCENT", "refresh_frequency": "DAILY", "requires_entities": ["ORDER", "PRODUCT"], "natural_language_aliases": ["gross margin", "gross profit", "markup", "margin percentage", "gm%"], "aggregation_type": "RATIO"},
  {"metric_id": "CUSTOMER_LTV", "name": "Customer Lifetime Value", "description": "Average revenue per unique customer over their lifetime", "formula": "ROUND(SUM(total_amount) / NULLIF(COUNT(DISTINCT customer_id), 0), 2)", "valid_range": [0, 1000000], "unit": "USD", "refresh_frequency": "WEEKLY", "requires_entities": ["CUSTOMER", "ORDER"], "natural_language_aliases": ["ltv", "lifetime value", "clv", "customer value", "avg customer value"], "aggregation_type": "RATIO"},
  {"metric_id": "CHURN_RATE", "name": "Churn Rate", "description": "Percentage of cancelled orders", "formula": "SUM(CASE WHEN status='Cancelled' THEN 1 ELSE 0 END)*100.0/NULLIF(COUNT(*),0)", "valid_range": [0, 100], "unit": "PERCENT", "refresh_frequency": "DAILY", "requires_entities": ["ORDER"], "natural_language_aliases": ["churn", "churned", "attrition", "churn rate", "cancellation rate", "lost customers"], "aggregation_type": "RATIO"},
  {"metric_id": "NEW_CUSTOMER_COUNT", "name": "New Customer Count", "description": "Customers placing their first order in the period", "formula": "COUNT(DISTINCT customer_id)", "valid_range": [0, 10000000], "unit": "COUNT", "refresh_frequency": "DAILY", "requires_entities": ["CUSTOMER", "ORDER"], "natural_language_aliases": ["new customers", "new signups", "acquired customers", "unique buyers", "new accounts"], "aggregation_type": "COUNT"},
  {"metric_id": "RETURN_RATE", "name": "Return Rate", "description": "Percentage of orders with an associated return", "formula": "COUNT(DISTINCT returns.order_id)*100.0/NULLIF(COUNT(DISTINCT orders.order_id),0)", "valid_range": [0, 100], "unit": "PERCENT", "refresh_frequency": "DAILY", "requires_entities": ["ORDER", "RETURN"], "natural_language_aliases": ["return rate", "returns", "returned orders", "refund rate", "reversal rate"], "aggregation_type": "RATIO"},
  {"metric_id": "CONVERSION_RATE", "name": "Conversion Rate", "description": "Percentage of sessions resulting in a purchase", "formula": "COUNT(DISTINCT orders.customer_id)/NULLIF(COUNT(DISTINCT sessions.session_id),0)", "valid_range": [0, 1], "unit": "RATIO", "refresh_frequency": "DAILY", "requires_entities": ["CUSTOMER", "ORDER"], "natural_language_aliases": ["conversion rate", "conversion", "converted", "purchase rate", "close rate"], "aggregation_type": "RATIO"},
  {"metric_id": "ACTIVE_CUSTOMERS", "name": "Active Customers", "description": "Customers with at least one non-cancelled order in the period", "formula": "COUNT(DISTINCT customer_id) WHERE status != 'Cancelled'", "valid_range": [0, 10000000], "unit": "COUNT", "refresh_frequency": "DAILY", "requires_entities": ["CUSTOMER", "ORDER"], "natural_language_aliases": ["active customers", "retention", "retained customers", "engaged customers"], "aggregation_type": "COUNT"},
  {"metric_id": "INVENTORY_TURNOVER", "name": "Inventory Turnover", "description": "Units sold relative to average stock on hand", "formula": "SUM(order_items.quantity)", "valid_range": [0, 100000000], "unit": "UNITS", "refresh_frequency": "DAILY", "requires_entities": ["ORDER_ITEM", "PRODUCT"], "natural_language_aliases": ["inventory", "stock", "in stock", "stock levels", "units sold", "inventory turnover"], "aggregation_type": "SUM"},
  {"metric_id": "TOTAL_ORDERS", "name": "Total Orders", "description": "Count of all orders placed in the period", "formula": "COUNT(*)", "valid_range": [0, 10000000], "unit": "COUNT", "refresh_frequency": "DAILY", "requires_entities": ["ORDER"], "natural_language_aliases": ["total orders", "order count", "number of orders", "orders placed", "order volume"], "aggregation_type": "COUNT"},
  {"metric_id": "NET_REVENUE", "name": "Net Revenue", "description": "Revenue after deducting returns and discounts", "formula": "SUM(total_amount) - SUM(returns.amount)", "valid_range": [0, 1000000000], "unit": "USD", "refresh_frequency": "DAILY", "requires_entities": ["ORDER", "RETURN"], "natural_language_aliases": ["net revenue", "net sales", "revenue after returns", "adjusted revenue"], "aggregation_type": "SUM"},
  {"metric_id": "COST_OF_GOODS_SOLD", "name": "Cost of Goods Sold", "description": "Total cost of products included in completed orders", "formula": "SUM(products.cost * order_items.quantity)", "valid_range": [0, 1000000000], "unit": "USD", "refresh_frequency": "DAILY", "requires_entities": ["ORDER", "PRODUCT", "ORDER_ITEM"], "natural_language_aliases": ["COGS", "cost of goods", "product cost", "cost of sales", "direct costs"], "aggregation_type": "SUM"},
  {"metric_id": "OPERATING_EXPENSES", "name": "Operating Expenses", "description": "Sum of all approved business expenses in the period", "formula": "SUM(expenses.amount) WHERE status='Approved'", "valid_range": [0, 1000000000], "unit": "USD", "refresh_frequency": "MONTHLY", "requires_entities": ["EXPENSE"], "natural_language_aliases": ["operating expenses", "opex", "expenses", "costs", "spending", "outlays", "overheads"], "aggregation_type": "SUM"},
  {"metric_id": "EBITDA", "name": "EBITDA", "description": "Earnings before interest, taxes, depreciation, and amortisation", "formula": "SUM(total_amount) - SUM(expenses.amount) + depreciation_addback", "valid_range": [-1000000000, 1000000000], "unit": "USD", "refresh_frequency": "QUARTERLY", "requires_entities": ["ORDER", "EXPENSE"], "natural_language_aliases": ["EBITDA", "operating profit", "operating earnings", "adjusted profit"], "aggregation_type": "SUM"},
  {"metric_id": "BUDGET_VARIANCE", "name": "Budget Variance", "description": "Difference between allocated and actual spend per budget line", "formula": "SUM(budget_items.allocated - budget_items.spent)", "valid_range": [-100000000, 100000000], "unit": "USD", "refresh_frequency": "MONTHLY", "requires_entities": ["BUDGET_ITEM"], "natural_language_aliases": ["budget variance", "budget vs actual", "over budget", "under budget", "spend variance", "variance"], "aggregation_type": "SUM"},
  {"metric_id": "HEADCOUNT", "name": "Headcount", "description": "Number of active employees", "formula": "COUNT(*) WHERE is_active = TRUE", "valid_range": [0, 1000000], "unit": "COUNT", "refresh_frequency": "MONTHLY", "requires_entities": ["EMPLOYEE"], "natural_language_aliases": ["headcount", "employees", "staff count", "workforce size", "total employees", "FTE"], "aggregation_type": "COUNT"},
  {"metric_id": "AVERAGE_SALARY", "name": "Average Salary", "description": "Mean base salary across employees", "formula": "AVG(employees.salary)", "valid_range": [0, 10000000], "unit": "USD", "refresh_frequency": "MONTHLY", "requires_entities": ["EMPLOYEE"], "natural_language_aliases": ["average salary", "mean salary", "avg pay", "average wage", "salary average"], "aggregation_type": "AVG"},
  {"metric_id": "TOTAL_PAYROLL", "name": "Total Payroll", "description": "Sum of all employee salaries and bonuses", "formula": "SUM(salaries.total_compensation)", "valid_range": [0, 10000000000], "unit": "USD", "refresh_frequency": "MONTHLY", "requires_entities": ["SALARY", "EMPLOYEE"], "natural_language_aliases": ["payroll", "total payroll", "total compensation", "salary bill", "wages bill", "people cost"], "aggregation_type": "SUM"},
  {"metric_id": "ATTRITION_RATE", "name": "Attrition Rate", "description": "Percentage of employees who left in the period", "formula": "COUNT(*) WHERE is_active=FALSE / AVG_HEADCOUNT * 100", "valid_range": [0, 100], "unit": "PERCENT", "refresh_frequency": "QUARTERLY", "requires_entities": ["EMPLOYEE"], "natural_language_aliases": ["attrition rate", "employee churn", "staff turnover", "turnover rate", "resignation rate"], "aggregation_type": "RATIO"},
  {"metric_id": "AVG_PERFORMANCE_SCORE", "name": "Average Performance Score", "description": "Mean performance review score across employees", "formula": "AVG(performance_reviews.score)", "valid_range": [1, 5], "unit": "SCORE", "refresh_frequency": "QUARTERLY", "requires_entities": ["PERFORMANCE_REVIEW"], "natural_language_aliases": ["performance score", "avg score", "average rating", "employee rating", "performance rating"], "aggregation_type": "AVG"},
  {"metric_id": "LEAVE_DAYS_TAKEN", "name": "Leave Days Taken", "description": "Total leave days consumed in the period", "formula": "SUM(leave_records.days_taken)", "valid_range": [0, 1000000], "unit": "DAYS", "refresh_frequency": "MONTHLY", "requires_entities": ["LEAVE_RECORD"], "natural_language_aliases": ["leave days", "days off", "absence days", "time off taken", "leave taken"], "aggregation_type": "SUM"},
  {"metric_id": "CAC", "name": "Customer Acquisition Cost", "description": "Marketing spend divided by new customers acquired", "formula": "SUM(campaigns.spend) / NULLIF(COUNT(DISTINCT new_customer_ids), 0)", "valid_range": [0, 100000], "unit": "USD", "refresh_frequency": "MONTHLY", "requires_entities": ["CAMPAIGN", "CUSTOMER"], "natural_language_aliases": ["CAC", "customer acquisition cost", "cost per acquisition", "CPA", "cost to acquire"], "aggregation_type": "RATIO"},
  {"metric_id": "ROAS", "name": "Return on Ad Spend", "description": "Revenue attributed to campaigns divided by total ad spend", "formula": "SUM(revenue_attributed) / NULLIF(SUM(spend), 0)", "valid_range": [0, 1000], "unit": "RATIO", "refresh_frequency": "DAILY", "requires_entities": ["CAMPAIGN"], "natural_language_aliases": ["ROAS", "return on ad spend", "ad efficiency", "campaign ROI", "marketing return"], "aggregation_type": "RATIO"},
  {"metric_id": "CTR", "name": "Click-Through Rate", "description": "Clicks divided by impressions for a campaign", "formula": "SUM(clicks) / NULLIF(SUM(impressions), 0) * 100", "valid_range": [0, 100], "unit": "PERCENT", "refresh_frequency": "DAILY", "requires_entities": ["CAMPAIGN"], "natural_language_aliases": ["CTR", "click-through rate", "click rate", "ad click rate", "engagement rate"], "aggregation_type": "RATIO"},
  {"metric_id": "TOTAL_AD_SPEND", "name": "Total Ad Spend", "description": "Total marketing campaign expenditure in the period", "formula": "SUM(campaigns.spend)", "valid_range": [0, 1000000000], "unit": "USD", "refresh_frequency": "DAILY", "requires_entities": ["CAMPAIGN"], "natural_language_aliases": ["ad spend", "marketing spend", "total spend", "media spend", "advertising cost"], "aggregation_type": "SUM"},
  {"metric_id": "MRR", "name": "Monthly Recurring Revenue", "description": "Sum of all active subscription MRR", "formula": "SUM(subscriptions.mrr) WHERE status='active'", "valid_range": [0, 1000000000], "unit": "USD", "refresh_frequency": "DAILY", "requires_entities": ["SUBSCRIPTION"], "natural_language_aliases": ["MRR", "monthly recurring revenue", "recurring revenue", "subscription revenue", "monthly subscription"], "aggregation_type": "SUM"},
  {"metric_id": "ARR", "name": "Annual Recurring Revenue", "description": "MRR multiplied by 12", "formula": "SUM(subscriptions.mrr) * 12 WHERE status='active'", "valid_range": [0, 10000000000], "unit": "USD", "refresh_frequency": "DAILY", "requires_entities": ["SUBSCRIPTION"], "natural_language_aliases": ["ARR", "annual recurring revenue", "annualised revenue", "yearly recurring revenue"], "aggregation_type": "SUM"},
  {"metric_id": "SUBSCRIPTION_CHURN", "name": "Subscription Churn Rate", "description": "Percentage of subscriptions cancelled in the period", "formula": "COUNT(*) WHERE status='cancelled' / TOTAL_SUBS * 100", "valid_range": [0, 100], "unit": "PERCENT", "refresh_frequency": "MONTHLY", "requires_entities": ["SUBSCRIPTION"], "natural_language_aliases": ["subscription churn", "plan cancellation rate", "subscriber loss", "subscription attrition"], "aggregation_type": "RATIO"},
  {"metric_id": "NPS", "name": "Net Promoter Score", "description": "Customer satisfaction score from support ticket satisfaction ratings", "formula": "AVG(support_tickets.satisfaction_score) * 20 - 100", "valid_range": [-100, 100], "unit": "SCORE", "refresh_frequency": "MONTHLY", "requires_entities": ["SUPPORT_TICKET"], "natural_language_aliases": ["NPS", "net promoter score", "customer satisfaction", "CSAT", "satisfaction score"], "aggregation_type": "AVG"},
  {"metric_id": "TICKET_RESOLUTION_TIME", "name": "Avg Ticket Resolution Time", "description": "Mean time in hours to resolve a support ticket", "formula": "AVG(support_tickets.resolution_time_hrs)", "valid_range": [0, 10000], "unit": "HOURS", "refresh_frequency": "DAILY", "requires_entities": ["SUPPORT_TICKET"], "natural_language_aliases": ["resolution time", "support time", "ticket resolution", "avg resolution", "response time", "SLA time"], "aggregation_type": "AVG"},
  {"metric_id": "OPEN_TICKETS", "name": "Open Tickets", "description": "Count of currently open or in-progress support tickets", "formula": "COUNT(*) WHERE status IN ('Open','In Progress')", "valid_range": [0, 1000000], "unit": "COUNT", "refresh_frequency": "HOURLY", "requires_entities": ["SUPPORT_TICKET"], "natural_language_aliases": ["open tickets", "pending tickets", "unresolved tickets", "active tickets", "ticket backlog"], "aggregation_type": "COUNT"},
  {"metric_id": "SUPPLIER_RATING", "name": "Average Supplier Rating", "description": "Mean supplier reliability rating", "formula": "AVG(suppliers.rating)", "valid_range": [0, 5], "unit": "SCORE", "refresh_frequency": "MONTHLY", "requires_entities": ["SUPPLIER"], "natural_language_aliases": ["supplier rating", "vendor rating", "supplier score", "supplier quality", "vendor performance"], "aggregation_type": "AVG"},
  {"metric_id": "LEAD_TIME", "name": "Average Lead Time", "description": "Mean days between reorder and delivery", "formula": "AVG(reorder_history.actual_delivery_date - reorder_history.reorder_date)", "valid_range": [0, 365], "unit": "DAYS", "refresh_frequency": "MONTHLY", "requires_entities": ["REORDER"], "natural_language_aliases": ["lead time", "delivery time", "supplier lead time", "order lead time", "replenishment time"], "aggregation_type": "AVG"},
  {"metric_id": "STOCKOUT_RATE", "name": "Stockout Rate", "description": "Percentage of products with zero available stock", "formula": "COUNT(*) WHERE quantity_available=0 / COUNT(*) * 100", "valid_range": [0, 100], "unit": "PERCENT", "refresh_frequency": "DAILY", "requires_entities": ["STOCK_LEVEL"], "natural_language_aliases": ["stockout rate", "out of stock", "stockout", "OOS rate", "availability rate"], "aggregation_type": "RATIO"},
  {"metric_id": "FILL_RATE", "name": "Fill Rate", "description": "Percentage of order demand fulfilled from existing stock", "formula": "COUNT(DISTINCT fulfilled_orders) / COUNT(*) * 100", "valid_range": [0, 100], "unit": "PERCENT", "refresh_frequency": "DAILY", "requires_entities": ["ORDER", "STOCK_LEVEL"], "natural_language_aliases": ["fill rate", "fulfilment rate", "order fulfilment", "stock fill rate", "service level"], "aggregation_type": "RATIO"},
  {"metric_id": "REORDER_COST", "name": "Total Reorder Cost", "description": "Total cost of inventory replenishment orders", "formula": "SUM(reorder_history.total_cost)", "valid_range": [0, 1000000000], "unit": "USD", "refresh_frequency": "MONTHLY", "requires_entities": ["REORDER"], "natural_language_aliases": ["reorder cost", "procurement cost", "replenishment cost", "purchase order cost", "buying cost"], "aggregation_type": "SUM"},
  {"metric_id": "DISCOUNT_USAGE", "name": "Discount Usage Rate", "description": "Percentage of orders using a discount code", "formula": "COUNT(*) WHERE discount_used=TRUE / COUNT(*) * 100", "valid_range": [0, 100], "unit": "PERCENT", "refresh_frequency": "DAILY", "requires_entities": ["ORDER", "DISCOUNT"], "natural_language_aliases": ["discount usage", "coupon usage", "promo code usage", "discount rate", "coupon rate"], "aggregation_type": "RATIO"},
  {"metric_id": "TOTAL_DISCOUNT_AMOUNT", "name": "Total Discount Amount", "description": "Total monetary value of discounts applied", "formula": "SUM(order_items.unit_price * order_items.quantity * order_items.discount_pct)", "valid_range": [0, 1000000000], "unit": "USD", "refresh_frequency": "DAILY", "requires_entities": ["ORDER_ITEM", "DISCOUNT"], "natural_language_aliases": ["total discounts", "discount amount", "coupon value", "promotions value", "deals given"], "aggregation_type": "SUM"},
  {"metric_id": "PIPELINE_VALUE", "name": "Pipeline Value", "description": "Total estimated value of open opportunities", "formula": "SUM(opportunities.value * opportunities.probability_pct / 100)", "valid_range": [0, 10000000000], "unit": "USD", "refresh_frequency": "DAILY", "requires_entities": ["OPPORTUNITY"], "natural_language_aliases": ["pipeline value", "sales pipeline", "opportunity value", "pipeline worth", "qualified pipeline", "weighted pipeline"], "aggregation_type": "SUM"},
  {"metric_id": "WIN_RATE", "name": "Opportunity Win Rate", "description": "Percentage of opportunities marked as won", "formula": "COUNT(*) WHERE won=TRUE / COUNT(*) * 100", "valid_range": [0, 100], "unit": "PERCENT", "refresh_frequency": "WEEKLY", "requires_entities": ["OPPORTUNITY"], "natural_language_aliases": ["win rate", "close rate", "opportunity win rate", "deal win rate", "conversion to close"], "aggregation_type": "RATIO"},
  {"metric_id": "FORECAST_ACCURACY", "name": "Forecast Accuracy", "description": "Mean accuracy percentage of predictions vs actuals", "formula": "AVG(forecasts.accuracy_pct)", "valid_range": [0, 100], "unit": "PERCENT", "refresh_frequency": "MONTHLY", "requires_entities": ["FORECAST"], "natural_language_aliases": ["forecast accuracy", "prediction accuracy", "model accuracy", "forecast error", "MAPE"], "aggregation_type": "AVG"},
  {"metric_id": "REVENUE_PER_EMPLOYEE", "name": "Revenue Per Employee", "description": "Total revenue divided by active headcount", "formula": "SUM(orders.total_amount) / NULLIF(COUNT(DISTINCT employees.employee_id),0)", "valid_range": [0, 100000000], "unit": "USD", "refresh_frequency": "MONTHLY", "requires_entities": ["ORDER", "EMPLOYEE"], "natural_language_aliases": ["revenue per employee", "revenue per head", "productivity", "output per employee"], "aggregation_type": "RATIO"},
  {"metric_id": "SHIPPING_COST_RATE", "name": "Shipping Cost Rate", "description": "Shipping costs as a percentage of revenue", "formula": "SUM(orders.shipping_cost) / NULLIF(SUM(orders.total_amount), 0) * 100", "valid_range": [0, 100], "unit": "PERCENT", "refresh_frequency": "DAILY", "requires_entities": ["ORDER"], "natural_language_aliases": ["shipping cost rate", "delivery cost rate", "logistics rate", "freight rate as pct"], "aggregation_type": "RATIO"},
  {"metric_id": "TAX_COLLECTED", "name": "Tax Collected", "description": "Total tax amount collected across all orders", "formula": "SUM(orders.tax_amount)", "valid_range": [0, 1000000000], "unit": "USD", "refresh_frequency": "MONTHLY", "requires_entities": ["ORDER"], "natural_language_aliases": ["tax collected", "total tax", "VAT collected", "sales tax", "GST", "tax amount"], "aggregation_type": "SUM"},
  {"metric_id": "PENDING_ORDERS", "name": "Pending Orders", "description": "Count of orders currently in Pending or Processing status", "formula": "COUNT(*) WHERE status IN ('Pending','Processing')", "valid_range": [0, 10000000], "unit": "COUNT", "refresh_frequency": "HOURLY", "requires_entities": ["ORDER"], "natural_language_aliases": ["pending orders", "processing orders", "open orders", "unfulfilled orders", "backlog"], "aggregation_type": "COUNT"},
  {"metric_id": "DELIVERED_ORDERS", "name": "Delivered Orders", "description": "Count of orders with Delivered status", "formula": "COUNT(*) WHERE status='Delivered'", "valid_range": [0, 10000000], "unit": "COUNT", "refresh_frequency": "DAILY", "requires_entities": ["ORDER"], "natural_language_aliases": ["delivered orders", "completed orders", "fulfilled orders", "deliveries", "completed deliveries"], "aggregation_type": "COUNT"},
  {"metric_id": "CANCELLED_ORDERS", "name": "Cancelled Orders", "description": "Count of cancelled orders in the period", "formula": "COUNT(*) WHERE status='Cancelled'", "valid_range": [0, 10000000], "unit": "COUNT", "refresh_frequency": "DAILY", "requires_entities": ["ORDER"], "natural_language_aliases": ["cancelled orders", "cancellations", "order cancellations", "void orders"], "aggregation_type": "COUNT"},
  {"metric_id": "AVG_ITEMS_PER_ORDER", "name": "Avg Items Per Order", "description": "Mean number of line items per order", "formula": "AVG(orders.item_count)", "valid_range": [0, 1000], "unit": "COUNT", "refresh_frequency": "DAILY", "requires_entities": ["ORDER"], "natural_language_aliases": ["items per order", "average basket size", "avg line items", "order depth", "basket depth"], "aggregation_type": "AVG"},
  {"metric_id": "TOTAL_UNITS_SOLD", "name": "Total Units Sold", "description": "Sum of all product quantities sold across order items", "formula": "SUM(order_items.quantity)", "valid_range": [0, 1000000000], "unit": "UNITS", "refresh_frequency": "DAILY", "requires_entities": ["ORDER_ITEM"], "natural_language_aliases": ["units sold", "total units", "quantity sold", "volume sold", "items sold"], "aggregation_type": "SUM"},
  {"metric_id": "RETENTION_RATE", "name": "Retention Rate", "description": "Percentage of prior-period customers who placed an order again", "formula": "COUNT(DISTINCT returning_customer_ids) / NULLIF(prior_period_customer_count, 0) * 100", "valid_range": [0, 100], "unit": "PERCENT", "refresh_frequency": "MONTHLY", "requires_entities": ["CUSTOMER", "ORDER"], "natural_language_aliases": ["retention rate", "customer retention", "repeat purchase rate", "returning customers", "loyalty rate"], "aggregation_type": "RATIO"},
  {"metric_id": "REPEAT_PURCHASE_RATE", "name": "Repeat Purchase Rate", "description": "Percentage of customers with more than one order", "formula": "COUNT(DISTINCT c.customer_id) WHERE order_count > 1 / COUNT(DISTINCT c.customer_id) * 100", "valid_range": [0, 100], "unit": "PERCENT", "refresh_frequency": "MONTHLY", "requires_entities": ["CUSTOMER"], "natural_language_aliases": ["repeat purchase rate", "re-purchase rate", "multi-order customers", "repeat customers"], "aggregation_type": "RATIO"},
  {"metric_id": "PRODUCT_VIEWS", "name": "Product Page Views", "description": "Total page views for product listings", "formula": "SUM(product_analytics.views)", "valid_range": [0, 10000000000], "unit": "COUNT", "refresh_frequency": "DAILY", "requires_entities": ["PRODUCT_ANALYTICS"], "natural_language_aliases": ["product views", "page views", "impressions", "product impressions", "views"], "aggregation_type": "SUM"},
  {"metric_id": "AVG_PRODUCT_RATING", "name": "Average Product Rating", "description": "Mean customer star rating across all products", "formula": "AVG(product_analytics.avg_rating)", "valid_range": [0, 5], "unit": "STARS", "refresh_frequency": "DAILY", "requires_entities": ["PRODUCT_ANALYTICS", "REVIEW"], "natural_language_aliases": ["product rating", "avg rating", "star rating", "customer rating", "average stars"], "aggregation_type": "AVG"},
  {"metric_id": "LOYALTY_POINTS_ISSUED", "name": "Loyalty Points Issued", "description": "Total loyalty points awarded to customers", "formula": "SUM(loyalty_points.points_delta) WHERE event_type='earned'", "valid_range": [0, 10000000000], "unit": "POINTS", "refresh_frequency": "DAILY", "requires_entities": ["LOYALTY_POINTS"], "natural_language_aliases": ["points issued", "rewards issued", "loyalty points given", "points earned", "reward points"], "aggregation_type": "SUM"},
  {"metric_id": "AFFILIATE_REVENUE", "name": "Affiliate Revenue", "description": "Revenue attributed to affiliate-driven traffic", "formula": "SUM(orders.total_amount) WHERE source='affiliate'", "valid_range": [0, 1000000000], "unit": "USD", "refresh_frequency": "DAILY", "requires_entities": ["AFFILIATE", "ORDER"], "natural_language_aliases": ["affiliate revenue", "partner revenue", "referral revenue", "referred sales"], "aggregation_type": "SUM"},
  {"metric_id": "CONTRACT_VALUE", "name": "Total Contract Value", "description": "Sum of all active contract values", "formula": "SUM(contracts.value) WHERE status='active'", "valid_range": [0, 100000000000], "unit": "USD", "refresh_frequency": "WEEKLY", "requires_entities": ["CONTRACT"], "natural_language_aliases": ["contract value", "TCV", "total contract value", "contracted revenue", "committed revenue"], "aggregation_type": "SUM"},
